<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpriteAtlasForge.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1600" d:DesignHeight="900"
        x:Class="SpriteAtlasForge.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding WindowTitle}"
        Width="1600" Height="900"
        Background="#1E1E1E">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#2D2D30">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}" InputGesture="Ctrl+N"/>
                <MenuItem Header="_Open Image..." Click="OnOpenImageClick" InputGesture="Ctrl+O"/>
                <MenuItem Header="Open _Project..." Click="OnOpenProjectClick" InputGesture="Ctrl+Shift+O"/>
                <Separator/>
                <MenuItem Header="_Save Project" Click="OnSaveProjectClick" InputGesture="Ctrl+S"/>
                <MenuItem Header="Save Project _As..." Click="OnSaveProjectClick"/>
                <Separator/>
                <MenuItem Header="_Export Atlas..." Click="OnExportAtlasClick" InputGesture="Ctrl+E"/>
                <Separator/>
                <MenuItem Header="E_xit"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGesture="Ctrl+Z"/>
                <MenuItem Header="_Redo" InputGesture="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Grid" Command="{Binding ToggleGridCommand}" InputGesture="G"/>
                <MenuItem Header="Zoom _In" Command="{Binding ZoomInCommand}" InputGesture="Ctrl+OemPlus"/>
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGesture="Ctrl+OemMinus"/>
                <MenuItem Header="_Fit to Screen" Command="{Binding FitToScreenCommand}" InputGesture="F"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Validate Project" Command="{Binding ValidateProjectCommand}" InputGesture="Ctrl+Shift+V"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="250,*,300">
            
            <!-- Left Panel - Groups List -->
            <Border Grid.Column="0" Classes="panel" Margin="4">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Classes="header" Text="Grid Groups" Margin="0,0,0,8"/>
                    
                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding GroupTree}"
                              Background="#252526"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              SelectionChanged="OnTreeViewSelectionChanged">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <!-- Icon -->
                                    <TextBlock Text="{Binding Icon}" 
                                               FontSize="14"
                                               IsVisible="{Binding IsCategory}"/>
                                    
                                    <!-- Color indicator for groups -->
                                    <Border Width="16" Height="16" 
                                            Background="{Binding Group.BorderColor}"
                                            CornerRadius="2"
                                            IsVisible="{Binding IsGroup}"/>
                                    
                                    <!-- Name -->
                                    <TextBlock Text="{Binding Name}"/>
                                    
                                    <!-- Frame count for groups -->
                                    <TextBlock Text="{Binding Group.Frames.Count, StringFormat='({0})'}"
                                               Foreground="#888888"
                                               FontSize="10"
                                               IsVisible="{Binding IsGroup}"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem:expanded">
                              <Setter Property="IsExpanded" Value="{Binding (vm:GroupTreeNode).IsExpanded, Mode=TwoWay}"/>
                            </Style>
                            <Style Selector="TreeViewItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="#094771"/>
                            </Style>
                        </TreeView.Styles>
                    </TreeView>
                    
                    <StackPanel Grid.Row="2" Spacing="4" Margin="0,8,0,0">
                        <!-- Auto Detect Button -->
                        <Button Content="🤖 Auto Detect" 
                                Command="{Binding AutoDetectCommand}"
                                Classes="primary"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Automatically detect and classify sprites"/>
                        
                        <!-- Region Selection -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Content="📐 Select Region" 
                                    Click="OnSelectRegionClick"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Click and drag to select a region for detection"/>
                            <Button Content="✖" 
                                    Click="OnClearSelectionClick"
                                    Width="32"
                                    ToolTip.Tip="Clear selection"/>
                        </StackPanel>
                        
                        <Separator Margin="0,4"/>
                        
                        <!-- Manual Controls -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Content="Add" Command="{Binding AddGroupCommand}"/>
                            <Button Content="Remove" 
                                    Command="{Binding RemoveGroupCommand}"
                                    CommandParameter="{Binding SelectedGroup}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Center Panel - Canvas & Logs -->
            <Border Grid.Column="1" Classes="panel" Margin="4">
                <Grid RowDefinitions="Auto,*,220">
                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                        <Button Content="🔍+" Command="{Binding ZoomInCommand}" ToolTip.Tip="Zoom In (Ctrl++)"/>
                        <Button Content="🔍-" Command="{Binding ZoomOutCommand}" ToolTip.Tip="Zoom Out (Ctrl+-)"/>
                        <Button Content="⊞" Command="{Binding FitToScreenCommand}" ToolTip.Tip="Fit to Screen (F)"/>
                        <Separator/>
                        <ToggleButton Content="Grid" IsChecked="{Binding ShowGrid}"/>
                        <Separator/>
                        <TextBlock Text="{Binding CanvasZoom, StringFormat='Zoom: {0:P0}'}" 
                                   VerticalAlignment="Center" 
                                   Margin="8,0"/>
                    </StackPanel>

                    <!-- Canvas Area -->
                    <Border Grid.Row="1" 
                            Background="#1E1E1E" 
                            BorderBrush="#3E3E42" 
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True">
                        <Grid ClipToBounds="True">
                            <TextBlock Text="Open an image to begin (Ctrl+O)" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Foreground="#666666"
                                       FontSize="16"
                                       IsVisible="{Binding !HasSourceImage}"/>
                            
                            <!-- Canvas control will be added programmatically -->
                            <Panel x:Name="CanvasContainer" ClipToBounds="True"/>
                        </Grid>
                    </Border>

                    <!-- Log Panel -->
                    <Border Grid.Row="2" 
                            Background="#1E1E1E" 
                            BorderBrush="#3E3E42" 
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="0,4,0,0">
                        <Grid RowDefinitions="Auto,*">
                            <!-- Log Header with Controls -->
                            <Border Grid.Row="0" 
                                    Background="#2D2D30" 
                                    BorderBrush="#3E3E42"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,4">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="📋 Logs" 
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    
                                    <!-- Filter Toggles -->
                                    <StackPanel Grid.Column="1" 
                                                Orientation="Horizontal" 
                                                Spacing="8" 
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <CheckBox Content="🔍 Debug" 
                                                  IsChecked="{Binding ShowDebugLogs}"
                                                  Foreground="#8E8E93"/>
                                        <CheckBox Content="ℹ️ Info" 
                                                  IsChecked="{Binding ShowInfoLogs}"
                                                  Foreground="#3794FF"/>
                                        <CheckBox Content="⚠️ Warning" 
                                                  IsChecked="{Binding ShowWarningLogs}"
                                                  Foreground="#FFB900"/>
                                        <CheckBox Content="❌ Error" 
                                                  IsChecked="{Binding ShowErrorLogs}"
                                                  Foreground="#E81123"/>
                                    </StackPanel>
                                    
                                    <!-- Action Buttons -->
                                    <StackPanel Grid.Column="2" 
                                                Orientation="Horizontal" 
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                        <ToggleButton Content="📜" 
                                                      IsChecked="{Binding AutoScrollLogs}"
                                                      ToolTip.Tip="Auto-scroll to latest"
                                                      Width="32" Height="24"/>
                                        <Button Content="🗑️" 
                                                Command="{Binding ClearLogsCommand}"
                                                ToolTip.Tip="Clear logs"
                                                Width="32" Height="24"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Log Entries List -->
                            <ScrollViewer Grid.Row="1" 
                                          x:Name="LogScrollViewer"
                                          Background="#252526">
                                <ItemsControl ItemsSource="{Binding LogEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent"
                                                    BorderBrush="#3E3E42"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,4">
                                                <Grid ColumnDefinitions="70,20,80,*">
                                                    <!-- Timestamp -->
                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding FormattedTime}"
                                                               Foreground="#808080"
                                                               FontFamily="Consolas"
                                                               FontSize="11"/>
                                                    
                                                    <!-- Icon -->
                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding Icon}"
                                                               FontSize="12"/>
                                                    
                                                    <!-- Category -->
                                                    <TextBlock Grid.Column="2" 
                                                               Text="{Binding Category}"
                                                               Foreground="{Binding LevelColor}"
                                                               FontWeight="Bold"
                                                               FontSize="11"/>
                                                    
                                                    <!-- Message -->
                                                    <TextBlock Grid.Column="3" 
                                                               Text="{Binding Message}"
                                                               TextWrapping="Wrap"
                                                               Foreground="#CCCCCC"
                                                               FontSize="11"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Panel - Properties -->
            <Border Grid.Column="2" Classes="panel" Margin="4">
                <ScrollViewer>
                    <StackPanel Spacing="8" IsVisible="{Binding SelectedGroup, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Classes="header" Text="Group Properties"/>
                        
                        <!-- Group Name -->
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Name:"/>
                            <TextBox Text="{Binding SelectedGroup.Name}"/>
                        </StackPanel>

                        <!-- Group Type -->
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Type:"/>
                            <ComboBox ItemsSource="{Binding GridGroupTypes}" 
                                      SelectedItem="{Binding SelectedGroup.Type}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Border Color -->
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Border Color:"/>
                            <TextBox Text="{Binding SelectedGroup.BorderColor}"/>
                        </StackPanel>

                        <Separator Margin="0,8"/>
                        <TextBlock Classes="header" Text="Grid Definition"/>

                        <!-- Origin -->
                        <Grid ColumnDefinitions="*,8,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="label" Text="Origin X:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.OriginX}" 
                                               Minimum="0" Increment="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Classes="label" Text="Origin Y:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.OriginY}" 
                                               Minimum="0" Increment="1"/>
                            </StackPanel>
                        </Grid>

                        <!-- Cell Size -->
                        <Grid ColumnDefinitions="*,8,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="label" Text="Cell Width:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.CellWidth}" 
                                               Minimum="1" Increment="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Classes="label" Text="Cell Height:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.CellHeight}" 
                                               Minimum="1" Increment="1"/>
                            </StackPanel>
                        </Grid>

                        <!-- Columns and Rows -->
                        <Grid ColumnDefinitions="*,8,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="label" Text="Columns:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.Columns}" 
                                               Minimum="1" Maximum="100" Increment="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Classes="label" Text="Rows:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.Rows}" 
                                               Minimum="1" Maximum="100" Increment="1"/>
                            </StackPanel>
                        </Grid>

                        <!-- Spacing and Padding -->
                        <Grid ColumnDefinitions="*,8,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="label" Text="Spacing:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.Spacing}" 
                                               Minimum="0" Increment="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Classes="label" Text="Padding:"/>
                                <NumericUpDown Value="{Binding SelectedGroup.GridDefinition.Padding}" 
                                               Minimum="0" Increment="1"/>
                            </StackPanel>
                        </Grid>

                        <!-- Generate Frames Button -->
                        <Button Content="Generate Frames" 
                                Command="{Binding GenerateFramesCommand}"
                                Classes="primary"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"/>

                        <!-- Frame Count -->
                        <TextBlock Classes="label" 
                                   Text="{Binding SelectedGroup.Frames.Count, StringFormat='Frames: {0}'}"
                                   HorizontalAlignment="Center"/>

                        <Separator Margin="0,8"/>
                        <TextBlock Classes="header" Text="Frame Optimization"/>

                        <!-- Auto Trim Button -->
                        <Button Content="✂️ Auto-Trim Frames" 
                                Command="{Binding AutoTrimSelectedGroupCommand}"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Automatically detect and trim empty space around sprites"/>

                        <!-- Reset Trim Button -->
                        <Button Content="↺ Reset Trim" 
                                Command="{Binding ResetTrimSelectedGroupCommand}"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Reset trim values to zero"/>

                        <!-- Toggle Background Removal -->
                        <Button Content="🎨 Toggle Background Removal" 
                                Command="{Binding ToggleBackgroundRemovalCommand}"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Enable/disable background color removal"/>

                        <Separator Margin="0,16"/>
                        <TextBlock Classes="header" Text="Individual Frames"/>

                        <!-- Frame List -->
                        <ListBox ItemsSource="{Binding SelectedGroup.Frames}"
                                 SelectedItem="{Binding SelectedFrame}"
                                 Height="200"
                                 Background="#252526"
                                 Margin="0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" 
                                                   Width="120"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Width, StringFormat='W:{0}'}" 
                                                   Width="45"
                                                   Foreground="#888888"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding Height, StringFormat='H:{0}'}" 
                                                   Width="45"
                                                   Foreground="#888888"
                                                   FontSize="11"/>
                                        <Border Width="12" Height="12"
                                                Background="{Binding BackgroundColor}"
                                                BorderBrush="#666666"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                IsVisible="{Binding BackgroundColor, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Selected Frame Editor -->
                        <StackPanel Spacing="8" 
                                    Margin="0,8"
                                    IsVisible="{Binding SelectedFrame, Converter={x:Static ObjectConverters.IsNotNull}}">
                            
                            <TextBlock Classes="label" Text="Selected Frame Properties:"/>

                            <!-- Frame Name -->
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Name:" FontSize="11"/>
                                <TextBox Text="{Binding SelectedFrame.Name}"/>
                            </StackPanel>

                            <!-- Position -->
                            <Grid ColumnDefinitions="*,8,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="label" Text="X:" FontSize="11"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.X}" 
                                                   Minimum="0" Increment="1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Classes="label" Text="Y:" FontSize="11"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.Y}" 
                                                   Minimum="0" Increment="1"/>
                                </StackPanel>
                            </Grid>

                            <!-- Size -->
                            <Grid ColumnDefinitions="*,8,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="label" Text="Width:" FontSize="11"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.Width}" 
                                                   Minimum="1" Increment="1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Classes="label" Text="Height:" FontSize="11"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.Height}" 
                                                   Minimum="1" Increment="1"/>
                                </StackPanel>
                            </Grid>

                            <!-- Trim -->
                            <TextBlock Classes="label" Text="Trim (pixels):" FontSize="11"/>
                            <Grid ColumnDefinitions="*,4,*,4,*,4,*">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="L" FontSize="10" Foreground="#888888"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.TrimLeft}" 
                                                   Minimum="0" Increment="1"
                                                   FormatString="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="R" FontSize="10" Foreground="#888888"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.TrimRight}" 
                                                   Minimum="0" Increment="1"
                                                   FormatString="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="2">
                                    <TextBlock Text="T" FontSize="10" Foreground="#888888"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.TrimTop}" 
                                                   Minimum="0" Increment="1"
                                                   FormatString="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="6" Spacing="2">
                                    <TextBlock Text="B" FontSize="10" Foreground="#888888"/>
                                    <NumericUpDown Value="{Binding SelectedFrame.TrimBottom}" 
                                                   Minimum="0" Increment="1"
                                                   FormatString="0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Background Color -->
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Background Color:" FontSize="11"/>
                                <TextBox Text="{Binding SelectedFrame.BackgroundColor}"
                                         Watermark="#FF00FF"/>
                            </StackPanel>

                            <!-- Remove Background -->
                            <CheckBox Content="Remove Background"
                                      IsChecked="{Binding SelectedFrame.RemoveBackground}"/>

                            <!-- Effective Size Display -->
                            <Border Background="#1E1E1E"
                                    BorderBrush="#3E3E42"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="8,4">
                                <TextBlock FontSize="11" Foreground="#888888">
                                    <Run Text="Effective: "/>
                                    <Run Text="{Binding SelectedFrame.Width}"/>
                                    <Run Text="-"/>
                                    <Run Text="{Binding SelectedFrame.TrimLeft}"/>
                                    <Run Text="-"/>
                                    <Run Text="{Binding SelectedFrame.TrimRight}"/>
                                    <Run Text="×"/>
                                    <Run Text="{Binding SelectedFrame.Height}"/>
                                    <Run Text="-"/>
                                    <Run Text="{Binding SelectedFrame.TrimTop}"/>
                                    <Run Text="-"/>
                                    <Run Text="{Binding SelectedFrame.TrimBottom}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Validation Messages Section -->
                        <Border Background="#2D2D30"
                                BorderBrush="#3E3E42"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8"
                                Margin="0,16,0,8">
                            <StackPanel Spacing="8">
                                <!-- Header -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Classes="header" 
                                               Text="⚠️ Validation"
                                               Foreground="#FFB900"/>
                                    <Border Grid.Column="1"
                                            Background="#FFB900"
                                            CornerRadius="10"
                                            Padding="8,2"
                                            IsVisible="{Binding ValidationMessages.Count}">
                                        <TextBlock Text="{Binding ValidationMessages.Count}"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   Foreground="#000000"/>
                                    </Border>
                                </Grid>
                                
                                <Separator Background="#3E3E42"/>
                                
                                <!-- Validation Button (always visible) -->
                                <Button Content="🔍 Validate Project"
                                        Command="{Binding ValidateProjectCommand}"
                                        HorizontalAlignment="Stretch"
                                        Classes="primary"
                                        ToolTip.Tip="Check project for errors and warnings"/>
                                
                                <!-- Messages List (only when has messages) -->
                                <Border IsVisible="{Binding ValidationMessages.Count}"
                                        Background="#1E1E1E"
                                        BorderBrush="#3E3E42"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="4">
                                    <ScrollViewer MaxHeight="250">
                                        <ItemsControl ItemsSource="{Binding ValidationMessages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="Transparent"
                                                            BorderBrush="#3E3E42"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="8,6"
                                                            Margin="0,2">
                                                        <StackPanel Spacing="4">
                                                            <!-- Icon + Message -->
                                                            <Grid ColumnDefinitions="24,*">
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding SeverityIcon}"
                                                                           FontSize="16"
                                                                           VerticalAlignment="Top"
                                                                           Margin="0,0,4,0"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Message}"
                                                                           TextWrapping="Wrap"
                                                                           Foreground="{Binding SeverityColor}"
                                                                           FontSize="12"
                                                                           LineHeight="16"/>
                                                            </Grid>
                                                            
                                                            <!-- Source/Location -->
                                                            <TextBlock Text="{Binding Source}"
                                                                       Foreground="#808080"
                                                                       FontSize="10"
                                                                       Margin="24,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                
                                <!-- Empty state message - показывается когда нет ошибок -->
                                <Border Background="#1E1E1E"
                                        BorderBrush="#10893E"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="0,4"
                                        IsVisible="{Binding !ValidationMessages.Count}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0"
                                                   Text="✅"
                                                   FontSize="16"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="No validation issues"
                                                   Foreground="#10893E"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,8"/>
                        <TextBlock Classes="header" Text="Frame Preview"/>

                        <!-- Preview Container -->
                        <Border Background="#282828" 
                                BorderBrush="#3E3E42" 
                                BorderThickness="1"
                                CornerRadius="4"
                                Height="150"
                                Margin="0,8">
                            <Panel x:Name="PreviewContainer"/>
                        </Border>

                        <!-- Preview Controls -->
                        <Grid ColumnDefinitions="*,*,*" Margin="0,4">
                            <Button Grid.Column="0" Content="▶ Play" x:Name="PlayButton" Click="OnPlayPreview"/>
                            <Button Grid.Column="1" Content="⏸ Pause" x:Name="PauseButton" Click="OnPausePreview"/>
                            <Button Grid.Column="2" Content="⏹ Stop" x:Name="StopButton" Click="OnStopPreview"/>
                        </Grid>

                        <!-- FPS Control -->
                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <TextBlock Classes="label" Text="Preview FPS:"/>
                            <NumericUpDown Value="{Binding SelectedGroup.PreviewFps}" 
                                           Minimum="1" Maximum="60" Increment="1"
                                           ValueChanged="OnPreviewFpsChanged"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#007ACC" Padding="8,4">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusText}" 
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding ValidationMessages.Count, StringFormat='Validation Messages: {0}'}" 
                               Foreground="White"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ValidationMessages.Count}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
